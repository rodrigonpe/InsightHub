@page "/attendance"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using InsightHub.Admin.Models
@inject HttpClient Http

<h1>Horários de Atendimento</h1>
@if (businessHours is null)
{
    <p>Carregando horários...</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Dia</th>
                <th>Status</th>
                <th>Horário</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in businessHours)
            {
                <tr>
                    <td>@item.DayName</td>
                    <td>@(item.IsOpen ? "Aberto" : "Fechado")</td>
                    <td>@item.Schedule</td>
                    <td>
                        <button class="btn btn-sm btn-primary" @onclick="() => Edit(item)">
                            Editar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
@if (selectedBusinessHour is not null)
{
    <div class="modal-backdrop-custom">

        <div class="modal-card">

            @if (isSaving)
            {
                <div class="saving-box">
                    <div class="spinner"></div>
                    <p>Salvando alterações...</p>
                </div>
            }
            else if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="success-box">
                    <div class="success-icon">✔</div>
                    <h4>Salvo com sucesso!</h4>
                </div>
            }
            else
            {
                <h3>Editar horário de atendimento</h3>

                <p class="day-title">
                    @selectedBusinessHour.DayName
                </p>

                <div class="mb-4">

                    <label class="switch-label">

                        <input type="checkbox"
                               checked="@selectedBusinessHour.IsOpen"
                               @onchange="OnOpenChanged" />

                        <span class="switch-slider"></span>

                        <span class="switch-text">
                            @(selectedBusinessHour.IsOpen ? "Aberto" : "Fechado")
                        </span>

                    </label>

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Horário inicial
                    </label>

                    <input class="form-control"
                           type="time"
                           @bind="selectedBusinessHour.StartTime"
                           disabled="@(!selectedBusinessHour.IsOpen)" />

                </div>

                <div class="mb-4">

                    <label class="form-label">
                        Horário final
                    </label>

                    <input class="form-control"
                           type="time"
                           @bind="selectedBusinessHour.EndTime"
                           disabled="@(!selectedBusinessHour.IsOpen)" />

                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">
                        @errorMessage
                    </div>
                }

                <div class="modal-actions">

                    <button class="btn btn-outline-secondary"
                            @onclick="CancelEdit">
                        Cancelar
                    </button>

                    <button class="btn btn-success"
                            @onclick="Save">
                        Salvar
                    </button>

                </div>
            }

        </div>

    </div>
}
@code {
    private List<BusinessHourResponse>? businessHours;
    private BusinessHourResponse? selectedBusinessHour;
    private string? successMessage;
    private string? errorMessage;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        businessHours = await Http.GetFromJsonAsync<List<BusinessHourResponse>>(
            "attendance/business-hours");
    }

    private void Edit(BusinessHourResponse businessHour)
    {
        successMessage = null;
        errorMessage = null;

        selectedBusinessHour = new BusinessHourResponse
        {
            Id = businessHour.Id,
            DayOfWeek = businessHour.DayOfWeek,
            DayName = businessHour.DayName,
            IsOpen = businessHour.IsOpen,
            StartTime = businessHour.StartTime,
            EndTime = businessHour.EndTime,
            Schedule = businessHour.Schedule,
            IsActive = businessHour.IsActive
        };
    }

    private void CancelEdit()
    {
        selectedBusinessHour = null;
        errorMessage = null;
    }

    private async Task Save()
    {
        if (selectedBusinessHour is null)
            return;

        isSaving = true;
        errorMessage = null;
        successMessage = null;

        var request = new
        {
            isOpen = selectedBusinessHour.IsOpen,
            startTime = selectedBusinessHour.StartTime,
            endTime = selectedBusinessHour.EndTime,
            updatedByUserId = Guid.Parse("bebc9d2b-b497-4a69-8823-2c525d65adbd")
        };

        var response = await Http.PutAsJsonAsync(
            $"attendance/business-hours/{selectedBusinessHour.DayOfWeek}",
            request);

        isSaving = false;

        if (!response.IsSuccessStatusCode)
        {
            errorMessage = await response.Content.ReadAsStringAsync();
            return;
        }

        businessHours = await Http.GetFromJsonAsync<List<BusinessHourResponse>>(
            "attendance/business-hours");

        successMessage = "Salvo!";

        await Task.Delay(900);

        selectedBusinessHour = null;
        successMessage = null;
    }
    private void OnOpenChanged(ChangeEventArgs e)
    {
        if (selectedBusinessHour is null)
            return;

        selectedBusinessHour.IsOpen = (bool)e.Value!;

        if (!selectedBusinessHour.IsOpen)
        {
            selectedBusinessHour.StartTime = null;
            selectedBusinessHour.EndTime = null;
        }
    }    
}
<style>

.modal-backdrop-custom{
    position:fixed;
    inset:0;
    background:rgba(0,0,0,.45);
    display:flex;
    justify-content:center;
    align-items:center;
    z-index:9999;
}

.modal-card{
    width:450px;
    background:white;
    border-radius:12px;
    padding:28px;
    box-shadow:0 15px 40px rgba(0,0,0,.25);
    animation:showModal .18s ease;
}

.day-title{
    font-size:18px;
    font-weight:600;
    margin-bottom:20px;
}

.modal-actions{
    display:flex;
    justify-content:flex-end;
    gap:10px;
    margin-top:25px;
}

.saving-box,
.success-box{
    height:220px;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
}

.spinner{
    width:42px;
    height:42px;
    border-radius:50%;
    border:4px solid #d9d9d9;
    border-top-color:#0d6efd;
    animation:spin .8s linear infinite;
    margin-bottom:20px;
}

.success-icon{
    font-size:54px;
    color:#198754;
    margin-bottom:10px;
}

.switch-label{
    display:flex;
    align-items:center;
    gap:12px;
    cursor:pointer;
    user-select:none;
}

.switch-label input{
    display:none;
}

.switch-slider{
    width:48px;
    height:26px;
    background:#dc3545;
    border-radius:30px;
    position:relative;
    transition:.2s;
}

.switch-slider::before{
    content:"";
    width:22px;
    height:22px;
    background:white;
    border-radius:50%;
    position:absolute;
    top:2px;
    left:2px;
    transition:.2s;
}

.switch-label input:checked + .switch-slider{
    background:#198754;
}

.switch-label input:checked + .switch-slider::before{
    transform:translateX(22px);
}

.switch-text{
    font-weight:600;
    font-size:16px;
}

@@keyframes spin{
    to{
        transform:rotate(360deg);
    }
}

@@keyframes showModal{
    from{
        opacity:0;
        transform:translateY(-15px) scale(.95);
    }
    to{
        opacity:1;
        transform:translateY(0) scale(1);
    }
}
</style>