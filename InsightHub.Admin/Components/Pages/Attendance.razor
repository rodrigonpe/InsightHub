@page "/attendance"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using InsightHub.Admin.Models
@using InsightHub.Admin.Services.Api
@inject BusinessHourService BusinessHourService

<h1>Horários de Atendimento</h1>
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}
@if (businessHours is null)
{
    <p>Carregando horários...</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Dia</th>
                <th>Status</th>
                <th>Horário</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in businessHours)
            {
                <tr>
                    <td>@item.DayName</td>
                    <td>@(item.IsOpen ? "Aberto" : "Fechado")</td>
                    <td>@item.Schedule</td>
                    <td>
                        <button class="btn btn-sm btn-primary" @onclick="() => Edit(item)">
                            Editar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (selectedBusinessHour is not null)
{
    <div class="modal-backdrop-custom">
        <div class="modal-card">

            @if (isSaving)
            {
                <div class="saving-box">
                    <div class="spinner"></div>
                    <p>Salvando alterações...</p>
                </div>
            }
            else if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="success-box">
                    <div class="success-icon">✔</div>
                    <h4>Salvo com sucesso!</h4>
                </div>
            }
            else
            {
                <h3>Editar horário de atendimento</h3>

                <p class="day-title">
                    @selectedBusinessHour.DayName
                </p>

                <div class="mb-4">
                    <label class="switch-label">
                        <input type="checkbox"
                               checked="@selectedBusinessHour.IsOpen"
                               @onchange="OnBusinessHourOpenChanged" />

                        <span class="switch-slider"></span>

                        <span class="switch-text">
                            @(selectedBusinessHour.IsOpen ? "Aberto" : "Fechado")
                        </span>
                    </label>
                </div>

                <div class="mb-3">
                    <label class="form-label">Horário inicial</label>

                    <input class="form-control"
                           type="time"
                           @bind="selectedBusinessHour.StartTime"
                           disabled="@(!selectedBusinessHour.IsOpen)" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Horário final</label>

                    <input class="form-control"
                           type="time"
                           @bind="selectedBusinessHour.EndTime"
                           disabled="@(!selectedBusinessHour.IsOpen)" />
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">
                        @errorMessage
                    </div>
                }

                <div class="modal-actions">
                    <button class="btn btn-outline-secondary" @onclick="CancelBusinessHourEdit">
                        Cancelar
                    </button>

                    <button class="btn btn-success" @onclick="SaveBusinessHour">
                        Salvar
                    </button>
                </div>
            }

        </div>
    </div>
}

@code {
    private List<BusinessHourResponse>? businessHours;
    private BusinessHourResponse? selectedBusinessHour;
    private string? successMessage;
    private string? errorMessage;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        await LoadBusinessHours();
    }

    private async Task LoadBusinessHours()
    {
        try
        {
            errorMessage = null;
            businessHours = await BusinessHourService.GetBusinessHoursAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void Edit(BusinessHourResponse businessHour)
    {
        successMessage = null;
        errorMessage = null;

        selectedBusinessHour = new BusinessHourResponse
        {
            Id = businessHour.Id,
            DayOfWeek = businessHour.DayOfWeek,
            DayName = businessHour.DayName,
            IsOpen = businessHour.IsOpen,
            StartTime = businessHour.StartTime,
            EndTime = businessHour.EndTime,
            Schedule = businessHour.Schedule,
            IsActive = businessHour.IsActive
        };
    }

    private void CancelBusinessHourEdit()
    {
        selectedBusinessHour = null;
        errorMessage = null;
        successMessage = null;
    }

    private void OnBusinessHourOpenChanged(ChangeEventArgs e)
    {
        if (selectedBusinessHour is null)
            return;

        selectedBusinessHour.IsOpen = (bool)e.Value!;

        if (!selectedBusinessHour.IsOpen)
        {
            selectedBusinessHour.StartTime = null;
            selectedBusinessHour.EndTime = null;
        }
    }

    private async Task SaveBusinessHour()
    {
        if (selectedBusinessHour is null)
            return;

        isSaving = true;
        errorMessage = null;
        successMessage = null;

        var success = await BusinessHourService.UpdateBusinessHourAsync(selectedBusinessHour);

        isSaving = false;

        if (!success)
        {
            errorMessage = "Não foi possível atualizar o horário padrão.";
            return;
        }

        await LoadBusinessHours();

        successMessage = "Salvo!";

        await Task.Delay(900);

        selectedBusinessHour = null;
        successMessage = null;
    }
}
<style>
    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .45);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .modal-card {
        width: 450px;
        background: white;
        border-radius: 12px;
        padding: 28px;
        box-shadow: 0 15px 40px rgba(0, 0, 0, .25);
        animation: showModal .18s ease;
    }

    .day-title {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 20px;
    }

    .modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 25px;
    }

    .saving-box,
    .success-box {
        height: 220px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    .spinner {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        border: 4px solid #d9d9d9;
        border-top-color: #0d6efd;
        animation: spin .8s linear infinite;
        margin-bottom: 20px;
    }

    .success-icon {
        font-size: 54px;
        color: #198754;
        margin-bottom: 10px;
    }

    .switch-label {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        user-select: none;
    }

    .switch-label input {
        display: none;
    }

    .switch-slider {
        width: 48px;
        height: 26px;
        background: #dc3545;
        border-radius: 30px;
        position: relative;
        transition: .2s;
    }

    .switch-slider::before {
        content: "";
        width: 22px;
        height: 22px;
        background: white;
        border-radius: 50%;
        position: absolute;
        top: 2px;
        left: 2px;
        transition: .2s;
    }

    .switch-label input:checked + .switch-slider {
        background: #198754;
    }

    .switch-label input:checked + .switch-slider::before {
        transform: translateX(22px);
    }

    .switch-text {
        font-weight: 600;
        font-size: 16px;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    @@keyframes showModal {
        from {
            opacity: 0;
            transform: translateY(-15px) scale(.95);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }
</style>
