@page "/attendance/exceptions"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using InsightHub.Admin.Models
@inject HttpClient Http

<h1>Horários Especiais</h1>

@if (exceptions is null)
{
    <p>Carregando exceções...</p>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-3">
        <button class="btn btn-primary" @onclick="OpenCreateModal">
            + Novo horário especial
        </button>

        <label class="mb-0">
            <input type="checkbox" @bind="includeInactive" @bind:after="LoadExceptions" />
            Exibir inativos
        </label>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Data</th>
                <th>Horário</th>
                <th>Motivo</th>
                <th>Situação</th> 
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in exceptions)
            {
                <tr class="@(!item.IsActive ? "table-secondary" : string.Empty)">
                    <td>@item.ExceptionDate.ToString("dd/MM/yyyy")</td>
                    <td>@item.Schedule</td>
                    <td>@item.Reason</td>
                    <td>@item.SituationLabel</td>
                    <td>
                        @if (item.IsActive)
                        {
                            <button class="btn btn-sm btn-primary"
                                    @onclick="() => OpenEditModal(item)">
                                ✏ Editar
                            </button>

                            <button class="btn btn-sm btn-warning"
                                    @onclick="() => ConfirmStatusChange(item, false)">
                                Inativar
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-success"
                                    @onclick="() => ConfirmStatusChange(item, true)">
                                ✔ Ativar
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (newException is not null)
{
    <div class="modal-backdrop-custom">
        <div class="modal-card">

            @if (isSaving)
            {
                <div class="saving-box">
                    <div class="spinner"></div>
                    <p>Salvando horário especial...</p>
                </div>
            }
            else if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="success-box">
                    <div class="success-icon">✔</div>
                    <h4>Salvo com sucesso!</h4>
                </div>
            }
            else
            {
                <h3>Novo horário especial</h3>

                <div class="mb-3">
                    <label class="form-label">Data</label>
                    <input class="form-control"
                           type="date"
                           @bind="newException.ExceptionDate" />
                </div>

                <div class="mb-3">
                    <label>
                        <input type="checkbox"
                               checked="@newException.IsOpen"
                               @onchange="OnCreateOpenChanged" />
                        Aberto
                    </label>
                </div>

                <div class="mb-3">
                    <label class="form-label">Horário inicial</label>
                    <input class="form-control"
                           type="time"
                           @bind="newException.StartTime"
                           disabled="@(!newException.IsOpen)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Horário final</label>
                    <input class="form-control"
                           type="time"
                           @bind="newException.EndTime"
                           disabled="@(!newException.IsOpen)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Motivo</label>
                    <input class="form-control"
                           @bind="newException.Reason" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Descrição</label>
                    <textarea class="form-control"
                              @bind="newException.Description"></textarea>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">
                        @errorMessage
                    </div>
                }

                <div class="modal-actions">
                    <button class="btn btn-outline-secondary" @onclick="CancelCreate">
                        Cancelar
                    </button>

                    <button class="btn btn-success" @onclick="SaveNewException">
                        Salvar
                    </button>
                </div>
            }
        </div>
    </div>
}

@if (exceptionToEdit is not null)
{
    <div class="modal-backdrop-custom">
        <div class="modal-card">

            @if (isSaving)
            {
                <div class="saving-box">
                    <div class="spinner"></div>
                    <p>Salvando alterações...</p>
                </div>
            }
            else if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="success-box">
                    <div class="success-icon">✔</div>
                    <h4>Salvo com sucesso!</h4>
                </div>
            }
            else
            {
                <h3>Editar horário especial</h3>

                <div class="mb-3">
                    <label class="form-label">Data</label>
                    <input class="form-control"
                           type="date"
                           @bind="exceptionToEdit.ExceptionDate" />
                </div>

                <div class="mb-3">
                    <label>
                        <input type="checkbox"
                               checked="@exceptionToEdit.IsOpen"
                               @onchange="OnEditOpenChanged" />
                        Aberto
                    </label>
                </div>

                <div class="mb-3">
                    <label class="form-label">Horário inicial</label>
                    <input class="form-control"
                           type="time"
                           @bind="exceptionToEdit.StartTime"
                           disabled="@(!exceptionToEdit.IsOpen)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Horário final</label>
                    <input class="form-control"
                           type="time"
                           @bind="exceptionToEdit.EndTime"
                           disabled="@(!exceptionToEdit.IsOpen)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Motivo</label>
                    <input class="form-control" @bind="exceptionToEdit.Reason" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Descrição</label>
                    <textarea class="form-control" @bind="exceptionToEdit.Description"></textarea>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">
                        @errorMessage
                    </div>
                }

                <div class="modal-actions">
                    <button class="btn btn-outline-secondary" @onclick="CancelEdit">
                        Cancelar
                    </button>

                    <button class="btn btn-success" @onclick="SaveEditException">
                        Salvar
                    </button>
                </div>
            }
        </div>
    </div>
}

@if (selectedStatusException is not null)
{
    <div class="modal-backdrop-custom">
        <div class="modal-card">

            @if (isChangingStatus)
            {
                <div class="saving-box">
                    <div class="spinner"></div>
                    <p>@(activateMode ? "Ativando horário especial..." : "Inativando horário especial...")</p>
                </div>
            }
            else
            {
                <h3>@(activateMode ? "Confirmar ativação" : "Confirmar inativação")</h3>

                <p>
                    Deseja realmente @(activateMode ? "ativar" : "inativar") o horário especial de
                    <strong>@selectedStatusException.ExceptionDate.ToString("dd/MM/yyyy")</strong>?
                </p>

                <p>
                    <strong>Motivo:</strong> @selectedStatusException.Reason
                </p>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">
                        @errorMessage
                    </div>
                }

                <div class="modal-actions">
                    <button class="btn btn-outline-secondary" @onclick="CancelStatusChange">
                        Cancelar
                    </button>

                    <button class="btn @(activateMode ? "btn-success" : "btn-warning")"
                            @onclick="ChangeExceptionStatus">
                        @(activateMode ? "Ativar" : "Inativar")
                    </button>
                </div>
            }

        </div>
    </div>
}

@code {
    private const string AdminUserId = "bebc9d2b-b497-4a69-8823-2c525d65adbd";

    private List<BusinessHourExceptionResponse>? exceptions;

    private CreateBusinessHourExceptionRequest? newException;
    private BusinessHourExceptionResponse? exceptionToEdit;
    private BusinessHourExceptionResponse? selectedStatusException;

    private string? successMessage;
    private string? errorMessage;

    private bool isSaving;
    private bool includeInactive;
    private bool activateMode;
    private bool isChangingStatus;

    protected override async Task OnInitializedAsync()
    {
        await LoadExceptions();
    }

    private async Task LoadExceptions()
    {
        var url = includeInactive
            ? "attendance/exceptions?includeInactive=true"
            : "attendance/exceptions";

        exceptions = await Http.GetFromJsonAsync<List<BusinessHourExceptionResponse>>(url);
    }
    private void OpenCreateModal()
    {
        successMessage = null;
        errorMessage = null;

        newException = new CreateBusinessHourExceptionRequest
        {
            ExceptionDate = DateOnly.FromDateTime(DateTime.Today),
            IsOpen = true,
            StartTime = new TimeOnly(8, 0),
            EndTime = new TimeOnly(17, 0)
        };
    }
    private void CancelCreate()
    {
        newException = null;
        errorMessage = null;
    }
    private void OnCreateOpenChanged(ChangeEventArgs e)
    {
        if (newException is null)
            return;

        newException.IsOpen = (bool)e.Value!;

        if (!newException.IsOpen)
        {
            newException.StartTime = null;
            newException.EndTime = null;
        }
    }
    private async Task SaveNewException()
    {
        if (newException is null)
            return;

        errorMessage = null;
        successMessage = null;

        if (newException.IsOpen &&
            (!newException.StartTime.HasValue || !newException.EndTime.HasValue))
        {
            errorMessage = "Informe o horário inicial e final.";
            return;
        }

        if (newException.IsOpen &&
            newException.StartTime >= newException.EndTime)
        {
            errorMessage = "O horário inicial deve ser menor que o horário final.";
            return;
        }

        isSaving = true;
        newException.CreatedByUserId = Guid.Parse(AdminUserId);

        HttpResponseMessage? response = await Http.PostAsJsonAsync(
            requestUri: "attendance/exceptions",
            newException);

        isSaving = false;

        if (!response.IsSuccessStatusCode)
        {
            errorMessage = await response.Content.ReadAsStringAsync();
            return;
        }

        await LoadExceptions();

        successMessage = "Salvo!";

        await Task.Delay( millisecondsDelay: 900);

        newException = null;
        successMessage = null;
    }
    private void OpenEditModal(BusinessHourExceptionResponse item)
    {
        successMessage = null;
        errorMessage = null;

        exceptionToEdit = new BusinessHourExceptionResponse
        {
            Id = item.Id,
            ExceptionDate = item.ExceptionDate,
            IsOpen = item.IsOpen,
            StartTime = item.StartTime,
            EndTime = item.EndTime,
            Reason = item.Reason,
            Description = item.Description,
            Schedule = item.Schedule,
            IsActive = item.IsActive
        };
    }
    private void CancelEdit()
    {
        exceptionToEdit = null;
        errorMessage = null;
    }
    private void OnEditOpenChanged(ChangeEventArgs e)
    {
        if (exceptionToEdit is null)
            return;

        exceptionToEdit.IsOpen = (bool)e.Value!;

        if (!exceptionToEdit.IsOpen)
        {
            exceptionToEdit.StartTime = null;
            exceptionToEdit.EndTime = null;
        }
    }
    private async Task SaveEditException()
    {
        if (exceptionToEdit is null)
            return;

        errorMessage = null;
        successMessage = null;

        if (exceptionToEdit.IsOpen &&
            (!exceptionToEdit.StartTime.HasValue || !exceptionToEdit.EndTime.HasValue))
        {
            errorMessage = "Informe o horário inicial e final.";
            return;
        }

        if (exceptionToEdit.IsOpen &&
            exceptionToEdit.StartTime >= exceptionToEdit.EndTime)
        {
            errorMessage = "O horário inicial deve ser menor que o horário final.";
            return;
        }

        isSaving = true;
        
        var request = new
        {
            exceptionDate = exceptionToEdit.ExceptionDate,
            isOpen = exceptionToEdit.IsOpen,
            startTime = exceptionToEdit.StartTime,
            endTime = exceptionToEdit.EndTime,
            reason = exceptionToEdit.Reason,
            description = exceptionToEdit.Description,
            updatedByUserId = Guid.Parse(AdminUserId)
        };

        var response = await Http.PutAsJsonAsync(
            $"attendance/exceptions/{exceptionToEdit.Id}",
            request);

        isSaving = false;

        if (!response.IsSuccessStatusCode)
        {
            errorMessage = await response.Content.ReadAsStringAsync();
            return;
        }

        await LoadExceptions();

        successMessage = "Salvo!";

        await Task.Delay(900);

        exceptionToEdit = null;
        successMessage = null;
    }
    private void ConfirmStatusChange(BusinessHourExceptionResponse item, bool activate)
    {
        selectedStatusException = item;
        activateMode = activate;
        successMessage = null;
        errorMessage = null;
    }
    private void CancelStatusChange()   
    {
        selectedStatusException = null;
        errorMessage = null;
    }
    private async Task ChangeExceptionStatus()
    {
        if (selectedStatusException is null)
            return;

        isChangingStatus = true;
        errorMessage = null;

        var action = activateMode ? "activate" : "deactivate";

        var response = await Http.PutAsync(
            $"attendance/exceptions/{selectedStatusException.Id}/{action}?updatedByUserId={AdminUserId}",
            null);

        isChangingStatus = false;

        if (!response.IsSuccessStatusCode)
        {
            errorMessage = await response.Content.ReadAsStringAsync();
            return;
        }

        await LoadExceptions();

        selectedStatusException = null;
        successMessage = activateMode ? "✔ Ativado!" : "✔ Inativado!";
    }
}

<style>
    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.45);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .modal-card {
        width: 450px;
        background: white;
        border-radius: 12px;
        padding: 28px;
        box-shadow: 0 15px 40px rgba(0,0,0,.25);
        animation: showModal .18s ease;
    }

    .modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 25px;
    }

    .saving-box,
    .success-box {
        height: 220px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    .spinner {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        border: 4px solid #d9d9d9;
        border-top-color: #0d6efd;
        animation: spin .8s linear infinite;
        margin-bottom: 20px;
    }

    .success-icon {
        font-size: 54px;
        color: #198754;
        margin-bottom: 10px;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    @@keyframes showModal {
        from {
            opacity: 0;
            transform: translateY(-15px) scale(.95);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }
</style>
