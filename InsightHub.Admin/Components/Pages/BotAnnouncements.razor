@page "/bot-announcements"
@rendermode InteractiveServer

@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using InsightHub.Admin.Models
@using InsightHub.Admin.Components.BotAnnouncements

@attribute [Authorize]
@inject HttpClient Http

<PageTitle>Comunicados do Bot</PageTitle>

<div class="page-header">
    <div>
        <h3 class="mb-1">Comunicados do Bot</h3>

        <div class="text-muted">
            Acompanhe comunicados agendados, em exibição, encerrados e inativos.
        </div>
    </div>

    <a class="btn btn-primary"
       href="/bot-announcements/new">
        Novo comunicado
    </a>
</div>

@if (!string.IsNullOrWhiteSpace(pageSuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show">
        @pageSuccessMessage

        <button type="button"
                class="btn-close"
                @onclick="() => pageSuccessMessage = null">
        </button>
    </div>
}

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border text-primary"
             role="status">
        </div>

        <span>Carregando comunicados...</span>
    </div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}
else
{
    <div class="summary-grid">
        <BotAnnouncementSummaryCard
            Title="Em exibição"
            Description="Ativos neste momento"
            Count="@CurrentAnnouncements.Count"
            CssClass="summary-live" />

        <BotAnnouncementSummaryCard
            Title="Agendados"
            Description="Início futuro"
            Count="@ScheduledAnnouncements.Count"
            CssClass="summary-scheduled" />

        <BotAnnouncementSummaryCard
            Title="Encerrados"
            Description="Vigência finalizada"
            Count="@ExpiredAnnouncements.Count"
            CssClass="summary-expired" />

        <BotAnnouncementSummaryCard
            Title="Inativos"
            Description="Desativados manualmente"
            Count="@InactiveAnnouncements.Count"
            CssClass="summary-inactive" />
    </div>

    <BotAnnouncementSection
        Title="Em exibição agora"
        Description="Comunicados que podem ser entregues ao cliente neste momento."
        Count="@CurrentAnnouncements.Count"
        ShowLiveIndicator="true"
        CssClass="live-section"
        EmptyMessage="Nenhum comunicado está em exibição neste momento.">

        @foreach (var item in CurrentAnnouncements)
        {
            <BotAnnouncementCard
                Item="@item"
                VisualState="live"
                CanEdit="@CanEdit(item)"
                CanExtend="@CanExtend(item)"
                CanReuse="@CanReuse(item)"
                OnExtend="@OpenExtendModal" />
        }
    </BotAnnouncementSection>

    <BotAnnouncementSection
        Title="Agendados"
        Description="Comunicados preparados para iniciar futuramente."
        Icon="🗓️"
        Count="@ScheduledAnnouncements.Count"
        EmptyMessage="Não há comunicados agendados.">

        @foreach (var item in ScheduledAnnouncements)
        {
            <BotAnnouncementCard
                Item="@item"
                VisualState="scheduled"
                CanEdit="@CanEdit(item)"
                CanExtend="@CanExtend(item)"
                CanReuse="@CanReuse(item)"
                OnExtend="@OpenExtendModal" />
        }
    </BotAnnouncementSection>

    <BotAnnouncementSection
        Title="Encerrados"
        Description="Comunicados cuja vigência já terminou."
        Icon="🕘"
        Count="@ExpiredAnnouncements.Count"
        EmptyMessage="Nenhum comunicado encerrado.">

        @foreach (var item in ExpiredAnnouncements)
        {
            <BotAnnouncementCard
                Item="@item"
                VisualState="expired"
                CanEdit="@CanEdit(item)"
                CanExtend="@CanExtend(item)"
                CanReuse="@CanReuse(item)"
                OnExtend="@OpenExtendModal" />
        }
    </BotAnnouncementSection>

    <BotAnnouncementSection
        Title="Inativos"
        Description="Comunicados desativados manualmente."
        Icon="⏸️"
        Count="@InactiveAnnouncements.Count"
        EmptyMessage="Nenhum comunicado inativo.">

        @foreach (var item in InactiveAnnouncements)
        {
            <BotAnnouncementCard
                Item="@item"
                VisualState="inactive"
                CanEdit="@CanEdit(item)"
                CanExtend="@CanExtend(item)"
                CanReuse="@CanReuse(item)"
                OnExtend="@OpenExtendModal" />
        }
    </BotAnnouncementSection>
}

@if (showExtendModal &&
     announcementToExtend is not null)
{
    <div class="modal-backdrop-custom">
        <div class="extend-modal card shadow">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Estender vigência</strong>

                <button type="button"
                        class="btn-close"
                        @onclick="CloseExtendModal">
                </button>
            </div>

            <div class="card-body">
                <p class="mb-2">
                    <strong>@announcementToExtend.Title</strong>
                </p>

                <p class="text-muted small">
                    Expiração atual:
                    @announcementToExtend.ExpiresAt?.ToString("dd/MM/yyyy HH:mm")
                </p>

                @if (!string.IsNullOrWhiteSpace(extendErrorMessage))
                {
                    <div class="alert alert-danger">
                        @extendErrorMessage
                    </div>
                }

                <label class="form-label">
                    Nova data e hora de expiração
                </label>

                <InputDate TValue="DateTime?"
                           Type="InputDateType.DateTimeLocal"
                           class="form-control"
                           min="@GetMinimumExtensionDate(announcementToExtend)"
                           @bind-Value="newExpirationDate" />
            </div>

            <div class="card-footer d-flex justify-content-end gap-2">
                <button type="button"
                        class="btn btn-secondary"
                        @onclick="CloseExtendModal">
                    Cancelar
                </button>

                <button type="button"
                        class="btn btn-success"
                        @onclick="ConfirmExtension">
                    Confirmar extensão
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<BotAnnouncementListItem> announcements = new();

    private bool isLoading = true;
    private string? errorMessage;
    private string? pageSuccessMessage;

    private bool showExtendModal;
    private BotAnnouncementListItem? announcementToExtend;
    private DateTime? newExpirationDate;
    private string? extendErrorMessage;

    private List<BotAnnouncementListItem> CurrentAnnouncements =>
        announcements
            .Where(IsCurrent)
            .OrderByDescending(item => item.StopBot)
            .ThenByDescending(item => item.Priority)
            .ThenByDescending(item => item.StartsAt)
            .ToList();

    private List<BotAnnouncementListItem> ScheduledAnnouncements =>
        announcements
            .Where(IsScheduled)
            .OrderBy(item => item.StartsAt)
            .ToList();

    private List<BotAnnouncementListItem> ExpiredAnnouncements =>
        announcements
            .Where(item =>
                IsExpired(item) &&
                item.Status != "INACTIVE")
            .OrderByDescending(item => item.ExpiresAt)
            .ToList();

    private List<BotAnnouncementListItem> InactiveAnnouncements =>
        announcements
            .Where(item => item.Status == "INACTIVE")
            .OrderByDescending(item => item.CreatedAt)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadAnnouncements();
    }

    private async Task LoadAnnouncements()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result =
                await Http.GetFromJsonAsync<List<BotAnnouncementListItem>>(
                    "/bot/announcements");

            announcements = result ?? new();
        }
        catch (Exception ex)
        {
            errorMessage =
                $"Erro ao carregar comunicados: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static bool IsExpired(
        BotAnnouncementListItem item)
    {
        return item.ExpiresAt.HasValue &&
               item.ExpiresAt.Value <= DateTime.Now;
    }

    private static bool HasStarted(
        BotAnnouncementListItem item)
    {
        return item.StartsAt.HasValue &&
               item.StartsAt.Value <= DateTime.Now;
    }

    private static bool IsScheduled(
        BotAnnouncementListItem item)
    {
        return item.Status == "ACTIVE" &&
               item.StartsAt.HasValue &&
               item.StartsAt.Value > DateTime.Now;
    }

    private static bool IsCurrent(
        BotAnnouncementListItem item)
    {
        return item.Status == "ACTIVE" &&
               HasStarted(item) &&
               !IsExpired(item);
    }

    private static bool CanEdit(
        BotAnnouncementListItem item)
    {
        return item.Status == "ACTIVE" &&
               !IsExpired(item);
    }

    private static bool CanExtend(
        BotAnnouncementListItem item)
    {
        return IsCurrent(item) &&
               item.ExpiresAt.HasValue;
    }

    private static bool CanReuse(
        BotAnnouncementListItem item)
    {
        return IsExpired(item) ||
               item.Status == "INACTIVE";
    }

    private void OpenExtendModal(
        BotAnnouncementListItem item)
    {
        announcementToExtend = item;
        newExpirationDate = item.ExpiresAt?.AddDays(1);
        extendErrorMessage = null;
        showExtendModal = true;
    }

    private void CloseExtendModal()
    {
        showExtendModal = false;
        announcementToExtend = null;
        newExpirationDate = null;
        extendErrorMessage = null;
    }

    private async Task ConfirmExtension()
    {
        extendErrorMessage = null;

        if (announcementToExtend is null)
            return;

        if (!newExpirationDate.HasValue)
        {
            extendErrorMessage =
                "Informe a nova data e hora de expiração.";

            return;
        }

        if (!CanExtend(announcementToExtend))
        {
            extendErrorMessage =
                "Este comunicado não está mais vigente e não pode ser estendido.";

            return;
        }

        if (newExpirationDate.Value <= DateTime.Now)
        {
            extendErrorMessage =
                "A nova expiração deve ser posterior ao momento atual.";

            return;
        }

        if (announcementToExtend.ExpiresAt.HasValue &&
            newExpirationDate.Value <= announcementToExtend.ExpiresAt.Value)
        {
            extendErrorMessage =
                "A nova expiração deve ser posterior à expiração atual.";

            return;
        }

        var request = new HttpRequestMessage(
            HttpMethod.Patch,
            $"/bot/announcements/{announcementToExtend.Id}/extend");

        request.Content = JsonContent.Create(new
        {
            expiresAt = newExpirationDate.Value
        });

        var response = await Http.SendAsync(request);

        if (!response.IsSuccessStatusCode)
        {
            var apiError =
                await response.Content.ReadAsStringAsync();

            extendErrorMessage =
                $"Não foi possível estender o comunicado. Retorno: {apiError}";

            return;
        }

        pageSuccessMessage =
            "Vigência estendida com sucesso.";

        CloseExtendModal();
        await LoadAnnouncements();
    }

    private static string GetMinimumExtensionDate(
        BotAnnouncementListItem item)
    {
        var minimum =
            item.ExpiresAt.HasValue &&
            item.ExpiresAt.Value > DateTime.Now
                ? item.ExpiresAt.Value.AddMinutes(1)
                : DateTime.Now.AddMinutes(1);

        return minimum.ToString("yyyy-MM-ddTHH:mm");
    }
}
